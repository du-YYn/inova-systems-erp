# ─── DATABASE ──────────────────────────────────────────────────────────────────
DB_NAME=inova_erp
DB_USER=inova_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_HOST=localhost
DB_PORT=5432

# ─── DJANGO ────────────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_real_secret_key
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── REDIS ─────────────────────────────────────────────────────────────────────
# Em produção defina REDIS_PASSWORD para habilitar autenticação no Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── EMAIL ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@inovasystems.com.br

# ─── FRONTEND ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── SENTRY (opcional) ─────────────────────────────────────────────────────────
# SENTRY_DSN=https://...

# ─── JWT COOKIES ───────────────────────────────────────────────────────────────
# Em produção (HTTPS): JWT_COOKIE_SECURE=true
JWT_COOKIE_SECURE=false

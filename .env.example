# ══════════════════════════════════════════════════════════════════════════════
# Inova Systems ERP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env (ele está no .gitignore).
# ══════════════════════════════════════════════════════════════════════════════

# ─── DATABASE ──────────────────────────────────────────────────────────────────
DB_NAME=inova_erp
DB_USER=inova_user
# PRODUÇÃO: use uma senha forte (min 24 chars, aleatória)
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_HOST=localhost
DB_PORT=5432

# ─── DJANGO ────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_real_secret_key

# DESENVOLVIMENTO: true | PRODUÇÃO: false (obrigatório)
DEBUG=false

# PRODUÇÃO: inclua o domínio real (ex: erp.inovasystems.com.br,www.erp.inovasystems.com.br)
ALLOWED_HOSTS=localhost,127.0.0.1

# PRODUÇÃO: use https:// com o domínio real
CORS_ALLOWED_ORIGINS=http://localhost:3000

# PRODUÇÃO: true — ativa redirect HTTP → HTTPS no Django (além do Nginx)
SECURE_SSL_REDIRECT=false

# ─── REDIS ─────────────────────────────────────────────────────────────────────
# PRODUÇÃO: use redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_URL=redis://redis:6379/0
# PRODUÇÃO: defina uma senha forte para o Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── EMAIL (Resend SMTP) ────────────────────────────────────────────────────────
# DESENVOLVIMENTO: django.core.mail.backends.console.EmailBackend
# PRODUÇÃO: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
# PRODUÇÃO: usuário fixo "resend" + chave API do Resend como senha
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=CHANGE_ME_RESEND_API_KEY
DEFAULT_FROM_EMAIL=noreply@inovasystemssolutions.com

# ─── FRONTEND ──────────────────────────────────────────────────────────────────
# PRODUÇÃO: use https:// com o domínio real da API
# IMPORTANTE: esta variável é embutida na build do Next.js (build-time, não runtime)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# URL do frontend usada em emails de password-reset (link enviado ao usuário).
# PRODUÇÃO: https://erp.seu-dominio.com
FRONTEND_URL=http://localhost:3000

# ─── DOMÍNIO (usado no nginx.conf para SSL) ────────────────────────────────────
# PRODUÇÃO: seu domínio real (ex: erp.inovasystems.com.br)
DOMAIN=localhost

# ─── JWT / COOKIES ─────────────────────────────────────────────────────────────
# PRODUÇÃO (HTTPS obrigatório): true
# DESENVOLVIMENTO (HTTP): false
JWT_COOKIE_SECURE=false
# Domínio dos cookies JWT — defina para compartilhar sessão entre subdomínios
# (erp., cadastro., parceiro.). DESENVOLVIMENTO: deixe vazio.
# PRODUÇÃO: .inovasystemssolutions.com (ou o seu apex precedido por ponto)
# JWT_COOKIE_DOMAIN=.inovasystemssolutions.com

# ─── CRIPTOGRAFIA AT-REST ──────────────────────────────────────────────────────
# Fernet key (base64 url-safe, 32 bytes) usada para criptografar `totp_secret`
# no banco. Mantenha em env separada do DB para que um vazamento de backup
# não comprometa o segundo fator. NUNCA rotacione sem migração — perderá
# acesso 2FA de todos os usuários ativos.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=CHANGE_ME_fernet_key_base64_32_bytes

# Senha de criptografia AES-256-CBC dos backups (scripts/backup_db.sh).
# Sem isso o backup falha fail-closed (não gera dump em texto-plano).
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
BACKUP_ENCRYPTION_KEY=CHANGE_ME_strong_passphrase_for_backups

# ─── INTEGRAÇÕES (API keys) ────────────────────────────────────────────────────
# Chave usada pelo formulário público do site (cadastro.inovasystemssolutions.com)
# para criar Prospects no ERP. Em produção é OBRIGATÓRIA — settings.py aborta
# se vazia. Gere com: python -c "import secrets; print(secrets.token_urlsafe(40))"
WEBSITE_API_KEY=CHANGE_ME_api_key_for_public_website_form

# Chave usada pelos workflows do n8n para autenticar webhooks de entrada.
# Vazia em dev (header X-N8N-API-Key será rejeitado).
N8N_API_KEY=CHANGE_ME_api_key_for_n8n_workflows

# ─── SENTRY (monitoramento de erros) ───────────────────────────────────────────
# PRODUÇÃO: obrigatório — obtenha em https://sentry.io
# DESENVOLVIMENTO: pode deixar vazio
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx

# ══════════════════════════════════════════════════════════════════════════════
# Inova Apresentação (subdomínio apresentacao.inovasystemssolutions.com)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Postgres dedicado (isolado do ERP) ───────────────────────────────────────
APRESENTACAO_DB_NAME=inova_apresentacao
APRESENTACAO_DB_USER=inova_apresentacao
APRESENTACAO_DB_PASSWORD=CHANGE_ME_strong_password_here

# ─── Django ───────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(50))"
APRESENTACAO_DJANGO_SECRET_KEY=CHANGE_ME_generate_a_real_secret_key
APRESENTACAO_DJANGO_DEBUG=False
APRESENTACAO_ALLOWED_HOSTS=apresentacao-api.inovasystemssolutions.com
APRESENTACAO_CORS_ORIGINS=https://apresentacao.inovasystemssolutions.com
APRESENTACAO_SECURE_SSL_REDIRECT=False
APRESENTACAO_LOG_LEVEL=INFO
APRESENTACAO_JWT_ACCESS_MINUTES=15
APRESENTACAO_JWT_REFRESH_DAYS=7

# SSO entre ERP ↔ Apresentação (mesmo valor nos dois lados)
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
PRESENTATION_SHARED_SECRET=CHANGE_ME_shared_secret_between_erp_and_apresentacao

# ─── Frontend Vite (build-time) ───────────────────────────────────────────────
APRESENTACAO_VITE_API_URL=https://apresentacao-api.inovasystemssolutions.com/api

# Configuração de cobertura — omitir apenas integrações externas e testes.
# Migrations são mantidas pois o pytest-django as exercita (100% cov) e
# refletem código que vai para produção.

[run]
source = .
omit =
    # Testes não entram no numerador
    */tests/*
    # Integrações externas com auth proprietária (webhooks n8n, portal
    # de parceiros, endpoints públicos com token) — cobertas por testes
    # de integração em staging, não unit tests
    sales/n8n_auth.py
    sales/n8n_views.py
    sales/n8n_urls.py
    sales/partner_urls.py
    sales/partner_views.py
    sales/views_public.py

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    except ImportError

show_missing = True
skip_covered = False

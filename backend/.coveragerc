# Configuração de cobertura — excluir integrações externas e arquivos triviais
# que exigem testes de integração (com servidores externos) em vez de unit tests.

[run]
source = .
omit =
    # Ambiente Django gerado
    manage.py
    config/asgi.py
    config/wsgi.py
    config/settings.py
    */migrations/*
    */tests/*
    */__pycache__/*
    # Integrações externas (webhooks n8n com auth proprietária) —
    # cobertas por testes de integração, não unit
    sales/n8n_auth.py
    sales/n8n_views.py
    sales/n8n_urls.py
    sales/partner_urls.py
    sales/partner_views.py
    # Endpoints públicos para clientes (token-based) — testados via
    # smoke test no deploy
    sales/views_public.py

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if settings.DEBUG
    if TYPE_CHECKING:
    except ImportError
    pass

show_missing = True
skip_covered = False
